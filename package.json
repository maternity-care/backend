{
  "name": "maternity-care-api",
  "version": "1.0.0",
  "description": "Production-ready NestJS backend for Maternity Care",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "build": "nest build",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md,yml,js}\"",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "migration:generate": "typeorm-ts-node-commonjs -d src/database/typeorm.config.ts migration:generate",
    "migration:run": "typeorm-ts-node-commonjs -d src/database/typeorm.config.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/database/typeorm.config.ts migration:revert",
    "migration:fresh": "typeorm-ts-node-commonjs -d src/database/typeorm.config.ts schema:drop && npm run migration:run",
    "migration:fresh:seed": "npm run migration:fresh && npm run seed",
    "migrate": "npm run migration:run",
    "migrate:rollback": "npm run migration:revert",
    "migrate:fresh": "npm run migration:fresh",
    "migrate:fresh:seed": "npm run migration:fresh:seed",
    "seed": "ts-node -r tsconfig-paths/register src/database/seeders/seed.ts",
    "migration:run:prod": "typeorm migration:run -d dist/database/typeorm.config.js",
    "migration:revert:prod": "typeorm migration:revert -d dist/database/typeorm.config.js",
    "migration:fresh:prod": "typeorm schema:drop -d dist/database/typeorm.config.js && npm run migration:run:prod",
    "seed:prod": "node dist/database/seeders/seed.js",
    "migration:fresh:seed:prod": "npm run migration:fresh:prod && npm run seed:prod",
    "db:seed": "npm run seed",
    "seed:roles-permissions": "npm run seed -- --class=RolesAndPermissionsSeeder",
    "seed:users": "npm run seed -- --class=UsersSeeder",
    "seed:settings": "npm run seed -- --class=SettingsSeeder"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.967.0",
    "@aws-sdk/s3-request-presigner": "^3.967.0",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.20",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.12",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.10.1",
    "mysql2": "^3.11.5",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.20",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.6.3"
  }
}
